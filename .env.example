# Copy this file to .env and fill in your values
# .env is gitignored — never commit real keys

ROBOFLOW_API_KEY=your_api_key_here
ROBOFLOW_WORKSPACE=wilfrids-workspace-8qcnd
ROBOFLOW_PROJECT=trailer-occupancy-detector
ROBOFLOW_VERSION=1

# Override serial port if needed (default: /dev/ttyACM0)
# SERIAL_PORT=/dev/ttyUSB0

# Override model path if needed
# MODEL_PATH=runs/classify/occupancy_detector/weights/best.pt
